class Solution {
public:
    int firstMissingPositive(vector<int>& nums) {
        int n = nums.size();
        
        for (int i = 0; i < n; ++i) {
            // While nums[i] is a positive integer within the valid range [1, n]
            // AND it's not already at its correct position (nums[i] - 1)
            // AND the target position doesn't already have the correct value (to avoid infinite loops)
            while (nums[i] > 0 && nums[i] <= n && nums[nums[i] - 1] != nums[i]) {
                swap(nums[i], nums[nums[i] - 1]);
            }
        }
        
        // After swapping, the first index 'i' where nums[i] != i + 1 
        // indicates that i + 1 is the missing number.
        for (int i = 0; i < n; ++i) {
            if (nums[i] != i + 1) {
                return i + 1;
            }
        }
        
        // If all numbers from 1 to n are present, the answer is n + 1
        return n + 1;
    }
};
